# Maintainer: Remit <hello@remit.md>
pkgname=remit-cli-bin
pkgver=0.5.6
pkgrel=1
pkgdesc="USDC payment protocol CLI for AI agents on Base"
arch=('x86_64' 'aarch64')
url="https://remit.md"
license=('MIT')
provides=('remit')
conflicts=('remit')

source_x86_64=("https://github.com/remit-md/remit-cli/releases/download/v${pkgver}/remit-x86_64-unknown-linux-musl.tar.gz")
source_aarch64=("https://github.com/remit-md/remit-cli/releases/download/v${pkgver}/remit-aarch64-unknown-linux-musl.tar.gz")

# Updated by CI on each release
sha256sums_x86_64=('SKIP')
sha256sums_aarch64=('SKIP')

package() {
    install -Dm755 remit "${pkgdir}/usr/bin/remit"
    install -Dm644 /dev/null "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
